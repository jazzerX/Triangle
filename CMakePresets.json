{
    "version": 10,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 29,
        "patch": 5
    },
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "displayName": "Configure Preset",
            "description": "Ninja generator",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/obj/${presetName}"     
        },
        {
            "inherits": "default",
            "name": "debug",
            "displayName": "Debug",
            "description": "Debug build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "debug",
                "OUTPUT_DIRECTORY": "${sourceDir}/build/exe/${presetName}"
            }
        },
        {
            "inherits": "default",
            "name": "release",
            "displayName": "Release",
            "description": "Release build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "release",
                "OUTPUT_DIRECTORY": "${sourceDir}/build/exe/${presetName}"
            }    
        }
    ],
    "buildPresets": [
        {
            "name": "Debug",
            "configurePreset": "debug"
        },
        {
            "name": "Release",
            "configurePreset": "release"
        }
    ]
}